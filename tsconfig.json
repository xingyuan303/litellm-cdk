{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "noImplicitAny": true,
    "noUnusedLocals": false
  },
  "exclude": ["node_modules", "cdk.out"]
}
